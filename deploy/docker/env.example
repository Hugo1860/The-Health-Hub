# 健闻局生产环境配置
# 复制此文件为 .env 并修改相应值

# 应用配置
NODE_ENV=production
NEXTAUTH_SECRET=your-super-secret-key-here-change-this
NEXTAUTH_URL=https://your-domain.com

# 数据库配置
DATABASE_URL=postgresql://postgres:password@postgres:5432/healthhub
POSTGRES_PASSWORD=your-secure-postgres-password
POSTGRES_USER=postgres
POSTGRES_DB=healthhub

# Redis 配置
REDIS_PASSWORD=your-secure-redis-password
REDIS_URL=redis://:your-secure-redis-password@redis:6379

# 文件上传配置
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE=100MB
ALLOWED_FILE_TYPES=mp3,wav,ogg,jpg,jpeg,png,gif

# 日志配置
LOG_LEVEL=info
LOG_PATH=/app/logs

# 安全配置
CORS_ORIGIN=https://your-domain.com
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX=100

# 监控配置
ENABLE_METRICS=true
METRICS_PORT=9090

# 备份配置
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

# 邮件配置 (可选)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# 第三方服务 (可选)
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
SENTRY_DSN=your-sentry-dsn
